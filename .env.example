# --- Workspace Storage Configuration ---
# The base directory on your host where all workspace data will live
ROOT_WORKSPACE_DIR=$HOME/.workspace

# Sub-folder name for the AES-256 encrypted data (The Vault)
CIPHER_DIR_NAME=encrypted_workspace

# Sub-folder name where your files appear when decrypted (The View)
MOUNT_DIR_NAME=decrypted_workspace

# --- Connection Configuration ---
# The port on your host that will map to the workspace SSH service
SSH_PORT=2222


# --- Docker & Identity Configuration ---
# Identity of the Docker container and image
CONTAINER_NAME=dev_workspace
IMAGE_NAME=dev_workspace

# Internal path INSIDE the container where SSH keys are managed
# (This maps to your decrypted folder on the host)
SSH_KEY_DIR=/home/dev/workspace/.ssh_keys

# The base Docker image to use for the development environment
BASE_IMAGE=ubuntu:24.04


# --- System & Security Configuration ---
# Path to the FUSE configuration file (varies by Linux distribution)
# Usually /etc/fuse.conf on Debian/Ubuntu/Fedora
FUSE_CONF=/etc/fuse.conf